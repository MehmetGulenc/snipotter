# Snipotter admin dashboard — environment variables.
#
# This file is the template. Copy to `.env.local` (gitignored) and fill
# in the real values. The dashboard talks to Supabase as a normal user,
# so the anon key is fine here — RLS policies on the schema only allow
# the service role to write, but reading is whitelisted to a single
# admin email at runtime in lib/auth.ts.

# Supabase project — the same one that powers app.snipotter.com.
NEXT_PUBLIC_SUPABASE_URL=https://oqiixlqfmjiljmpjnpbp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste anon key from Supabase project settings>

# Email allowlist — only this email can sign in. Magic-link login still
# works for any email in theory but the auth guard rejects everything
# else and forces sign-out.
NEXT_PUBLIC_ADMIN_EMAILS=mehmetgulenc5@gmail.com
