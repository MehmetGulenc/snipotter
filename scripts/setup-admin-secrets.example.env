# Snipotter admin — worker secret kurulum şablonu.
#
# Kullanım:
#   1. Bu dosyayı kopyala:
#        cp scripts/setup-admin-secrets.example.env ~/.snipotter-admin.env
#   2. ~/.snipotter-admin.env dosyasını editör'le aç ve değerleri doldur
#   3. ./scripts/setup-admin-secrets.sh
#
# .env formatı: KEY=VALUE, satır başı '#' yorum. Tırnak gerekmez ama
# çok satırlı PEM gibi şeyleri base64'le (örnek altta).
#
# DİKKAT: Bu dosya ASLA repo'ya commit edilmemeli — ~/ev dizininde tut.

# ─── Mecburi (Supabase + cron auth) ───────────────────────────────

# Supabase project URL
SUPABASE_URL=https://oqiixlqfmjiljmpjnpbp.supabase.co

# Supabase service-role JWT (Studio → Project Settings → API → service_role)
# Anon key DEĞİL — service_role olmalı, "secret"/"reveal" gizli sürüm.
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...

# Rastgele uzun string. /run?secret= endpoint'ini koruyor. Üretmek için:
#   openssl rand -base64 32
CRON_TRIGGER_SECRET=

# ─── Opsiyonel: GitHub (rate limit 60→5000/h) ─────────────────────

# Public read-only personal access token. Boş bırakırsan anonim API
# kullanılır (saatte 60 istek — Snipotter ölçeği için yeterli).
GITHUB_TOKEN=

# ─── Opsiyonel: Microsoft Store ──────────────────────────────────

# Azure portal → Microsoft Entra ID → App registrations → New
# (Snipotter Admin Cron); Tenant ID + Application ID + Secret üret.
# Sonra Partner Center → Account settings → Tenants altında
# uygulamaya analytics permission ver.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ─── Opsiyonel: Google Play (Android yayınlanınca) ───────────────

# Google Cloud Console → IAM → Service Accounts → JSON key indir.
# Tek satıra base64'le: base64 -i ~/Downloads/sa-key.json | tr -d '\n'
PLAY_SERVICE_ACCOUNT_JSON_B64=

# ─── Opsiyonel: Cloudflare Workers Analytics ─────────────────────

# Cloudflare dashboard → My Profile → API Tokens → Create Token →
# "Read Analytics" template (account-level Analytics:Read).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
