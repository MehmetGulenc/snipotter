# Snipotter Environment Variables
# Hepsi optional gibi görünür ama sync ve AI için gereklidir.
# Production build'de bu değişkenler renderer'a embed edilir, hassas key'leri main process'te tutmak için gerekirse ileride server-side proxy eklenebilir.

# === Supabase ===
# https://supabase.com -> Project Settings -> API
MAIN_VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
MAIN_VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...
RENDERER_VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
RENDERER_VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# === Anthropic Claude (primary AI) ===
# https://console.anthropic.com/settings/keys
MAIN_VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# === Google Gemini (fallback AI) ===
# https://aistudio.google.com/apikey
MAIN_VITE_GEMINI_API_KEY=AIza...

# === App Settings ===
MAIN_VITE_APP_NAME=Snipotter
